# =========================================================
# WhaleStream Enterprise
# .gitignore
# =========================================================

# ==========================
# Python
# ==========================
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.python-version

# ==========================
# Virtual Environment
# ==========================
.venv/
venv/
env/

# ==========================
# IDE
# ==========================
.vscode/
.idea/
*.code-workspace

# ==========================
# Environment Variables
# ==========================
.env
.env.*

# ==========================
# Secrets (Never Commit)
# ==========================
config_bybit.py
*.pem
*.key

# ==========================
# Runtime Logs
# ==========================
logs/
*.log
*.jsonl

# ==========================
# Runtime Output
# ==========================
output/
reports/

# ==========================
# Recovery Runtime Artifacts
# ==========================
history/test_recovery/
history/recovery_state.json
history/recovery_report.json
history/runtime.lock

# ==========================
# Temporary Files
# ==========================
*.tmp
*.bak
*.cache

# ==========================
# Databases
# ==========================
*.db
*.sqlite
*.sqlite3

# ==========================
# Runtime CSV Files
# ==========================
trade_journal.csv
history/execution_journal.csv

# ==========================
# Excel
# ==========================
*.xlsx

# ==========================
# Operating System
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Test / Coverage
# ==========================
.pytest_cache/
.coverage
htmlcov/

# ==========================
# Build
# ==========================
dist/
build/
*.egg-info/